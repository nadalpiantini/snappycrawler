// ============================================
// DEPLOYMENT - Production Configuration
// ============================================

# Environment Configuration Template
# Copy this file to .env.production for production deployment

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# ============================================
# PERFORMANCE
# ============================================
# Node.js memory limit (MB)
NODE_MAX_OLD_SPACE_SIZE=4096

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Sentry (optional - for error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/id
SENTRY_AUTH_TOKEN=your-sentry-token

# Vercel Analytics (automatic)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-vercel-project-id

# ============================================
# API KEYS (Optional)
# ============================================
# Claude API (for code generation)
CLAUDE_API_KEY=sk-ant-...

# Upstash Redis (for caching)
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# RATE LIMITING
# ============================================
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=10000

# ============================================
# CORS
# ============================================
# Allow origins (comma-separated)
ALLOWED_ORIGINS=https://your-domain.com,https://app.vercel.app

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_CACHE_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_RATE_LIMITING=true
