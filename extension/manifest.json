{
  "manifest_version": 3,
  "name": "Snappy - Page Snapshot Exporter",
  "version": "2.0.0",
  "description": "Export HTML, visible text, and UX flows from any webpage to JSON",
  "permissions": ["activeTab", "downloads", "scripting"],
  "action": {
    "default_title": "Export Snappy Snapshot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "content.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
