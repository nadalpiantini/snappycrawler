{
  "manifest_version": 3,
  "name": "Snappy - Page Snapshot Exporter",
  "version": "2.1.0",
  "description": "Export HTML, text, design tokens, and UX intelligence from any webpage",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "crawler.html",
    "default_title": "Snappy Crawler",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "content.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
